# API Keys for LLM providers
GROQ_API_KEY=
CEREBRAS_API_KEY=

# OpenAI-compatible provider (used when providerMode=openai_compatible)
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini

# OpenCode Zen provider (used when providerMode=opencode_zen)
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_MODEL=gpt-5.4-mini

# Ollama / LM Studio provider (used when providerMode=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=llama3.1

# Provider mode: default | demo | openai_compatible | opencode_zen | ollama
LIVING_BUNKER_PROVIDER_MODE=default

# Force demo mode (no real LLM calls)
LIVING_BUNKER_DEMO=0

# Custom models per character (optional, defaults shown)
# MODEL_RED=qwen/qwen3-32b
# MODEL_BLUE=llama3.1-8b
# MODEL_GREEN=llama-3.3-70b
# MODEL_LUNA=llama-3.3-70b
# MODEL_DOPPELGANGER=openai/gpt-oss-20b
# MODEL_ARCHITECT=llama-3.3-70b
# MODEL_ARCHITECT_FALLBACK=openai/gpt-oss-120b
